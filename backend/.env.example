# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# ── Website API: Telegram уведомления о заявках с сайта ──────
# Создай бота через @BotFather, получи токен
TG_NOTIFY_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Свой chat_id — узнай через @userinfobot
TG_NOTIFY_CHAT_ID=123456789

# ── Telegram Bot (ассистент для клиентов) ────────────────────
TG_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Твой личный chat_id (куда бот шлёт уведомления о новых клиентах)
TG_OWNER_CHAT_ID=123456789

# ── Claude API ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# ── Персонализация ассистента ─────────────────────────────────
ASSISTANT_NAME=Помощник
OWNER_NAME=Вусал

# ── CORS (через запятую) ─────────────────────────────────────
ALLOWED_ORIGINS=https://your-site.vercel.app,http://localhost:5173

# ── Sentry (опционально) ─────────────────────────────────────
SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0

# ── Окружение ────────────────────────────────────────────────
ENVIRONMENT=production
